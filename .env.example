# HuggingFace token — FREE, get from https://huggingface.co/settings/tokens
# Create a token with "Read" access (that's all that's needed)
HF_TOKEN=your_huggingface_token_here

# Groq API key — FREE tier available at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Corporate proxy — required if you're on a corporate network
# Find yours: run this in PowerShell:
#   [System.Net.WebRequest]::GetSystemWebProxy().GetProxy("https://api.groq.com")
# Then paste the result below, e.g.: http://proxy.company.com:8080
HTTPS_PROXY=
